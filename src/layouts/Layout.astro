---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "@/config";
import "@/styles/global.css";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  scrollSmooth?: boolean;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage || "og.png",
  ogType,
  canonicalURL: canonicalURLProp,
  pubDatetime,
  modDatetime,
  structuredData: customStructuredData,
  scrollSmooth = false,
} = Astro.props;

const siteBaseURL = new URL(SITE.website);
const siteBasePath = siteBaseURL.pathname.endsWith("/")
  ? siteBaseURL.pathname
  : `${siteBaseURL.pathname}/`;
const currentPathname = Astro.url.pathname;
const canonicalPathname =
  currentPathname.endsWith("/") || currentPathname.includes(".")
    ? currentPathname
    : `${currentPathname}/`;
const canonicalURL = canonicalURLProp
  ? new URL(canonicalURLProp, siteBaseURL)
  : new URL(canonicalPathname, Astro.url);

const toSiteURL = (pathOrURL: string) => {
  try {
    return new URL(pathOrURL);
  } catch {
    const cleanPath = pathOrURL.startsWith(siteBasePath)
      ? pathOrURL.slice(siteBasePath.length)
      : pathOrURL.replace(/^\/+/, "");

    return new URL(cleanPath, siteBaseURL);
  }
};

const socialImageURL = toSiteURL(ogImage);
const faviconURL = new URL("favicon.svg", siteBaseURL);
const sitemapURL = new URL("sitemap-index.xml", siteBaseURL);
const rssURL = new URL("rss.xml", siteBaseURL);
const personData = {
  "@type": "Person",
  "@id": new URL("#person", siteBaseURL).href,
  name: SITE.name,
  alternateName: [SITE.nameEn, SITE.author],
  url: SITE.profile,
  email: SITE.email,
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "九州大学",
    url: "https://www.kyushu-u.ac.jp/",
  },
  sameAs: SITE.sameAs,
};

const defaultStructuredData = pubDatetime
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: `${title}`,
      image: `${socialImageURL}`,
      datePublished: `${pubDatetime?.toISOString()}`,
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [
        {
          "@type": "Person",
          name: `${author}`,
          ...(profile && { url: profile }),
        },
      ],
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: title,
      description,
      url: canonicalURL.href,
      image: socialImageURL.href,
      inLanguage: SITE.lang,
      author: personData,
    };

const structuredData = customStructuredData ?? defaultStructuredData;
const resolvedOgType = ogType ?? (pubDatetime ? "article" : "website");
---

<!doctype html>
<html
  dir={SITE.dir}
  lang=`${SITE.lang ?? "en"}`
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={faviconURL} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Load Font -->
    <Font
      cssVariable="--font-main"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" type="application/xml" href={sitemapURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={rssURL}
    />

    <meta name="theme-color" content="" />

    {
      // If PUBLIC_GOOGLE_SITE_VERIFICATION is set in the environment variable,
      // include google-site-verification tag in the heading
      // Learn more: https://support.google.com/webmasters/answer/9008080#meta_tag_verification&zippy=%2Chtml-tag
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    <ClientRouter />

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        function getPreferTheme() {
          return "dark";
          // return window.matchMedia("(prefers-color-scheme: dark)").matches
          //   ? "dark"
          //   : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-ETHS7GP7HH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args) {
        dataLayer.push(args);
      }
      gtag("js", new Date());

      gtag("config", "G-ETHS7GP7HH");
    </script>
  </head>
  <body>
    <slot />

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>
  </body>
</html>
